    replacement_chunks {
      target_content: "  return (\n    <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col h-full\" id=\"data-importer-panel\">\n      <div className=\"p-4 bg-slate-50 border-b border-slate-100 flex items-center justify-between\">\n        <div>\n          <h3 className=\"font-display font-semibold text-slate-800 text-sm flex items-center gap-2\">\n            <Database className=\"w-4 h-4 text-slate-500\" />\n            Integrasi & Editor Database Koleksi\n          </h3>\n          <p className=\"text-xs text-slate-500 mt-0.5\">\n            Gunakan sampel standar Indonesia atau masukkan data nasabah & histori aktivitas Anda sendiri.\n          </p>\n        </div>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"flex border-b border-slate-100 bg-slate-50/50 text-xs px-2 pt-2\">\n        <button\n          onClick={() => setActiveTab(\"presets\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t-md transition-colors ${\n            activeTab === \"presets\"\n              ? \"border-blue-600 text-blue-600 bg-white\"\n              : \"border-transparent text-slate-500 hover:text-slate-900\"\n          }`}\n          id=\"tab-presets\"\n        >\n          Daftar Dataset Sampel\n        </button>\n        <button\n          onClick={() => setActiveTab(\"customer\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t-md transition-colors ${\n            activeTab === \"customer\"\n              ? \"border-blue-600 text-blue-600 bg-white\"\n              : \"border-transparent text-slate-500 hover:text-slate-900\"\n          }`}\n          id=\"tab-customer\"\n        >\n          Data Nasabah\n        </button>\n        <button\n          onClick={() => setActiveTab(\"profiles\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t-md transition-colors ${\n            activeTab === \"profiles\"\n              ? \"border-blue-600 text-blue-600 bg-white\"\n              : \"border-transparent text-slate-500 hover:text-slate-900\"\n          }`}\n          id=\"tab-profiles\"\n        >\n          Profil Kolektor\n        </button>\n        <button\n          onClick={() => {\n            setActiveTab(\"raw_json\");\n            setRawText(JSON.stringify({ customer, profiles, activities }, null, 2));\n          }}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t-md transition-colors ${\n            activeTab === \"raw_json\"\n              ? \"border-blue-600 text-blue-600 bg-white\"\n              : \"border-transparent text-slate-500 hover:text-slate-900\"\n          }`}\n          id=\"tab-raw-json\"\n        >\n          Impor/Ekspor JSON\n        </button>\n      </div>\n\n      {/* Tab Panels */}\n      <div className=\"p-4 flex-1 overflow-auto max-h-[420px] text-xs\">\n        {/* Presets Panel */}\n        {activeTab === \"presets\" && (\n          <div className=\"space-y-4\">\n            <p className=\"text-slate-500 leading-relaxed text-[11px]\">\n              Klik tombol di bawah untuk memuat set data instan sebagai simulasi. Berisi data geografis Indonesia (Bali & Jakarta):\n            </p>\n            <div className=\"grid grid-cols-1 gap-2.5\">\n              {sampleDatasets.map((sample, idx) => (\n                <div\n                  key={sample.name}\n                  className=\"p-3 rounded-xl border border-slate-100 hover:border-slate-200 bg-slate-50 hover:bg-slate-100/50 cursor-pointer transition-all flex flex-col gap-1 text-left\"\n                  onClick={() => loadPreset(idx)}\n                  id={`preset-card-${idx}`}\n                >\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-semibold text-slate-800\">{sample.name}</span>\n                    <span className=\"text-[10px] bg-slate-200 px-1.5 py-0.5 rounded text-slate-600 font-medium\">\n                      {sample.profiles.length} Kolektor\n                    </span>\n                  </div>\n                  <p className=\"text-slate-500 text-[10px] mt-0.5 leading-relaxed\">{sample.description}</p>\n                </div>\n              ))}\n            </div>\n\n            {/* Reference Date control */}\n            <div className=\"border-t border-slate-100 pt-3 mt-4\">\n              <div className=\"flex items-center gap-1.5 text-slate-700 font-semibold mb-2\">\n                <Sliders className=\"w-3.5 h-3.5 text-slate-500\" />\n                <span>Tanggal Acuan Analisis Recency</span>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <input\n                  type=\"date\"\n                  value={referenceDate}\n                  onChange={(e) => onChangeReferenceDate(e.target.value)}\n                  className=\"bg-white border border-slate-200 rounded px-2.5 py-1.5 shadow-sm text-[11px] font-mono text-slate-700 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n                  id=\"input-ref-date\"\n                />\n                <span className=\"text-[10px] text-slate-500 leading-normal font-sans\">\n                  Sistem mengevaluasi bobot aktivitas berdasarkan selisih waktu dari tanggal ini.\n                </span>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* Customer Panel */}\n        {activeTab === \"customer\" && (\n          <div className=\"space-y-3\">\n            <p className=\"text-slate-500 leading-relaxed text-[11px] mb-2\">\n              Sunting koordinat geocoding dan alamat nasabah baru untuk mengonfigurasi titik pencarian teritori harian:\n            </p>\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div>\n                <label className=\"block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1\">\n                  ID Nasabah\n                </label>\n                <input\n                  type=\"text\"\n                  value={customer.customer_id}\n                  onChange={(e) => handleCustomerChange(\"customer_id\", e.target.value)}\n                  className=\"w-full bg-slate-50 hover:bg-slate-100/50 border border-slate-200 rounded p-2 focus:bg-white tracking-wide\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1\">\n                  Nama Nasabah\n                </label>\n                <input\n                  type=\"text\"\n                  value={customer.customer_name}\n                  onChange={(e) => handleCustomerChange(\"customer_name\", e.target.value)}\n                  className=\"w-full bg-slate-50 hover:bg-slate-100/50 border border-slate-200 rounded p-2 focus:bg-white transition-colors\"\n                />\n              </div>\n            </div>\n            <div>\n              <label className=\"block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1\">\n                Alamat Fisik Lengkap\n              </label>\n              <textarea\n                value={customer.address}\n                onChange={(e) => handleCustomerChange(\"address\", e.target.value)}\n                rows={2}\n                className=\"w-full bg-slate-50 hover:bg-slate-100/50 border border-slate-200 rounded p-2 focus:bg-white font-sans text-[11px] leading-relaxed transition-colors resize-none\"\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div>\n                <label className=\"block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1\">\n                  Latitude Koordinat\n                </label>\n                <input\n                  type=\"number\"\n                  step=\"0.0001\"\n                  value={customer.latitude}\n                  onChange={(e) => handleCustomerChange(\"latitude\", parseFloat(e.target.value) || 0)}\n                  className=\"w-full bg-slate-50 hover:bg-slate-100/50 border border-slate-200 rounded p-2 focus:bg-white font-mono tracking-wide\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1\">\n                  Longitude Koordinat\n                </label>\n                <input\n                  type=\"number\"\n                  step=\"0.0001\"\n                  value={customer.longitude}\n                  onChange={(e) => handleCustomerChange(\"longitude\", parseFloat(e.target.value) || 0)}\n                  className=\"w-full bg-slate-50 hover:bg-slate-100/50 border border-slate-200 rounded p-2 focus:bg-white font-mono tracking-wide\"\n                />\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* Profiles Panel */}\n        {activeTab === \"profiles\" && (\n          <div className=\"space-y-3\">\n            <div className=\"flex items-center justify-between mb-1\">\n              <span className=\"text-slate-500 leading-normal text-[11px]\">\n                Kelola metadata profil beban kerja harian kolektor:\n              </span>\n              <button\n                onClick={handleAddProfile}\n                className=\"flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white font-medium px-2 py-1 rounded transition-colors text-[10px] shadow-sm\"\n                id=\"btn-add-profile\"\n              >\n                <Plus className=\"w-3.5 h-3.5\" />\n                Tambah Kolektor\n              </button>\n            </div>\n\n            {profiles.length === 0 ? (\n              <div className=\"p-4 bg-slate-50 border border-dashed border-slate-200 rounded-lg text-slate-500 text-center\">\n                Belum ada data kolektor. Tambahkan kolektor atau load sampel.\n              </div>\n            ) : (\n              <div className=\"space-y-2 max-h-[220px] overflow-auto pr-1\">\n                {profiles.map((prof, pIdx) => (\n                  <div\n                    key={pIdx}\n                    className=\"p-3 bg-slate-50 rounded-xl border border-slate-150 flex flex-col gap-2 relative group\"\n                  >\n                    <button\n                      onClick={() => handleDeleteProfile(pIdx)}\n                      className=\"absolute top-2 right-2 text-slate-400 hover:text-red-600 p-1 rounded hover:bg-slate-200/50 transition-colors opacity-0 group-hover:opacity-100\"\n                      title=\"Hapus Profil\"\n                      id={`btn-del-profile-${pIdx}`}\n                    >\n                      <Trash2 className=\"w-3.5 h-3.5\" />\n                    </button>\n                    <div className=\"grid grid-cols-4 gap-2\">\n                      <div>\n                        <label className=\"block text-[8px] font-mono text-slate-500 mb-0.5\">KODE</label>\n                        <input\n                          type=\"text\"\n                          value={prof.collector_code}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"collector_code\", e.target.value)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono font-bold\"\n                        />\n                      </div>\n                      <div>\n                        <label className=\"block text-[8px] font-mono text-slate-500 mb-0.5\">NASABAH AKTIF</label>\n                        <input\n                          type=\"number\"\n                          value={prof.active_customers}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"active_customers\", parseInt(e.target.value) || 0)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono\"\n                        />\n                      </div>\n                      <div className=\"col-span-2\">\n                        <label className=\"block text-[8px] font-mono text-slate-500 mb-0.5\">NOMI. HISTORIS (Rp)</label>\n                        <input\n                          type=\"number\"\n                          value={prof.total_nominal}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"total_nominal\", parseInt(e.target.value) || 0)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono\"\n                        />\n                      </div>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        )}\n\n        {/* Raw JSON import/export panel */}\n        {activeTab === \"raw_json\" && (\n          <div className=\"space-y-3\">\n            <p className=\"text-slate-500 leading-normal text-[11px]\">\n              Gunakan editor JSON di bawah untuk memproses tumpukan database yang kompleks sekaligus (mendukung impor dump MySQL terstruktur):\n            </p>\n            <textarea\n              value={rawText}\n              onChange={(e) => setRawText(e.target.value)}\n              rows={8}\n              className=\"w-full bg-slate-900 border border-slate-800 text-slate-200 rounded p-3 font-mono text-[10px] leading-relaxed resize-y focus:outline-none focus:ring-1 focus:ring-blue-500\"\n              placeholder=\"Masukkan JSON murni berisi data customer, profiles, dan activities\"\n            />\n            {jsonError && (\n              <div className=\"p-2.5 bg-red-50 border border-red-150 rounded text-red-700 flex items-start gap-1.5 leading-relaxed text-[10px]\">\n                <AlertTriangle className=\"w-3.5 h-3.5 flex-shrink-0 mt-0.5\" />\n                <span>Error: {jsonError}</span>\n              </div>\n            )}\n            <div className=\"flex gap-2 justify-end\">\n              <button\n                onClick={() => setRawText(JSON.stringify({ customer, profiles, activities }, null, 2))}\n                className=\"px-2.5 py-1.5 border border-slate-200 rounded text-slate-600 hover:bg-slate-50 transition-colors\"\n                id=\"btn-sync-raw\"\n              >\n                Sinkronkan dengan Layar\n              </button>\n              <button\n                onClick={handleRawSubmit}\n                className=\"px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium shadow-sm transition-colors\"\n                id=\"btn-apply-raw\"\n              >\n                Terapkan Data\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* Summary Footer bar */}\n      <div className=\"p-3 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-[11px] text-slate-500\">\n        <span className=\"font-medium text-slate-700\">Database Saat Ini:</span>\n        <span className=\"flex items-center gap-1\">\n          {profiles.length} Profil Kolektor | {activities.length} Aktivitas GPS\n        </span>\n      </div>\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"bg-white rounded-xl border border-slate-200 shadow-xs overflow-hidden flex flex-col h-full\" id=\"data-importer-panel\">\n      <div className=\"p-4 bg-slate-50/50 border-b border-slate-200 flex items-center justify-between\">\n        <div>\n          <h3 className=\"text-[11px] uppercase tracking-wider text-slate-400 font-bold flex items-center gap-2\">\n            <Database className=\"w-3.5 h-3.5\" />\n            Integrasi & Editor Database Koleksi\n          </h3>\n          <p className=\"text-xs text-slate-500 mt-1\">\n            Gunakan sampel standar Indonesia atau masukkan data nasabah & histori aktivitas Anda sendiri.\n          </p>\n        </div>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"flex border-b border-slate-200 bg-slate-50/20 text-[11px] px-2 pt-1.5\">\n        <button\n          onClick={() => setActiveTab(\"presets\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t transition-colors ${\n            activeTab === \"presets\"\n              ? \"border-slate-800 text-slate-800 bg-white\"\n              : \"border-transparent text-slate-400 hover:text-slate-700\"\n          }`}\n          id=\"tab-presets\"\n        >\n          Daftar Dataset Sampel\n        </button>\n        <button\n          onClick={() => setActiveTab(\"customer\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t transition-colors ${\n            activeTab === \"customer\"\n              ? \"border-slate-800 text-slate-800 bg-white\"\n              : \"border-transparent text-slate-400 hover:text-slate-700\"\n          }`}\n          id=\"tab-customer\"\n        >\n          Data Nasabah\n        </button>\n        <button\n          onClick={() => setActiveTab(\"profiles\")}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t transition-colors ${\n            activeTab === \"profiles\"\n              ? \"border-slate-800 text-slate-800 bg-white\"\n              : \"border-transparent text-slate-400 hover:text-slate-700\"\n          }`}\n          id=\"tab-profiles\"\n        >\n          Profil Kolektor\n        </button>\n        <button\n          onClick={() => {\n            setActiveTab(\"raw_json\");\n            setRawText(JSON.stringify({ customer, profiles, activities }, null, 2));\n          }}\n          className={`px-3 py-2 font-medium border-b-2 rounded-t transition-colors ${\n            activeTab === \"raw_json\"\n              ? \"border-slate-800 text-slate-800 bg-white\"\n              : \"border-transparent text-slate-400 hover:text-slate-700\"\n          }`}\n          id=\"tab-raw-json\"\n        >\n          Impor/Ekspor JSON\n        </button>\n      </div>\n\n      {/* Tab Panels */}\n      <div className=\"p-4 flex-1 overflow-auto max-h-[420px] text-xs\">\n        {/* Presets Panel */}\n        {activeTab === \"presets\" && (\n          <div className=\"space-y-4\">\n            <p className=\"text-slate-500 leading-relaxed text-[11px]\">\n              Klik tombol di bawah untuk memuat set data instan sebagai simulasi. Berisi data geografis Indonesia (Bali & Jakarta):\n            </p>\n            <div className=\"grid grid-cols-1 gap-2.5\">\n              {sampleDatasets.map((sample, idx) => (\n                <div\n                  key={sample.name}\n                  className=\"p-3 bg-white rounded border border-slate-200 hover:border-slate-300 hover:bg-slate-50 cursor-pointer transition-all flex flex-col gap-1 text-left\"\n                  onClick={() => loadPreset(idx)}\n                  id={`preset-card-${idx}`}\n                >\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-bold text-slate-700\">{sample.name}</span>\n                    <span className=\"text-[10px] bg-slate-100 border border-slate-200/65 px-1.5 py-0.5 rounded text-slate-600 font-medium\">\n                      {sample.profiles.length} Kolektor\n                    </span>\n                  </div>\n                  <p className=\"text-slate-500 text-[10px] mt-0.5 leading-relaxed\">{sample.description}</p>\n                </div>\n              ))}\n            </div>\n\n            {/* Reference Date control */}\n            <div className=\"border-t border-slate-100 pt-3 mt-4\">\n              <div className=\"flex items-center gap-1.5 text-slate-700 font-bold mb-2\">\n                <Sliders className=\"w-3.5 h-3.5 text-slate-400\" />\n                <span>Tanggal Acuan Analisis Recency</span>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <input\n                  type=\"date\"\n                  value={referenceDate}\n                  onChange={(e) => onChangeReferenceDate(e.target.value)}\n                  className=\"bg-white border border-slate-200 rounded px-2.5 py-1.5 text-[11px] font-mono text-slate-700 focus:outline-none focus:ring-1 focus:ring-slate-400\"\n                  id=\"input-ref-date\"\n                />\n                <span className=\"text-[10px] text-slate-500 leading-normal font-sans\">\n                  Sistem mengevaluasi bobot aktivitas berdasarkan selisih waktu dari tanggal ini.\n                </span>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* Customer Panel */}\n        {activeTab === \"customer\" && (\n          <div className=\"space-y-3\">\n            <p className=\"text-slate-500 leading-relaxed text-[11px] mb-2\">\n              Sunting koordinat geocoding dan alamat nasabah baru untuk mengonfigurasi titik pencarian teritori harian:\n            </p>\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div>\n                <label className=\"block text-[9px] font-mono text-slate-400 uppercase tracking-wider mb-1 font-bold\">\n                  ID Nasabah\n                </label>\n                <input\n                  type=\"text\"\n                  value={customer.customer_id}\n                  onChange={(e) => handleCustomerChange(\"customer_id\", e.target.value)}\n                  className=\"w-full bg-white border border-slate-200 rounded p-2 focus:bg-slate-50/50 tracking-wide outline-none focus:border-slate-400\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-[9px] font-mono text-slate-400 uppercase tracking-wider mb-1 font-bold\">\n                  Nama Nasabah\n                </label>\n                <input\n                  type=\"text\"\n                  value={customer.customer_name}\n                  onChange={(e) => handleCustomerChange(\"customer_name\", e.target.value)}\n                  className=\"w-full bg-white border border-slate-200 rounded p-2 focus:bg-slate-50/50 transition-colors outline-none focus:border-slate-400\"\n                />\n              </div>\n            </div>\n            <div>\n              <label className=\"block text-[9px] font-mono text-slate-400 uppercase tracking-wider mb-1 font-bold font-mono\">\n                Alamat Fisik Lengkap\n              </label>\n              <textarea\n                value={customer.address}\n                onChange={(e) => handleCustomerChange(\"address\", e.target.value)}\n                rows={2}\n                className=\"w-full bg-white border border-slate-200 rounded p-2 font-sans text-[11px] leading-relaxed transition-colors resize-none outline-none focus:border-slate-400\"\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div>\n                <label className=\"block text-[9px] font-mono text-slate-400 uppercase tracking-wider mb-1 font-bold\">\n                  Latitude Koordinat\n                </label>\n                <input\n                  type=\"number\"\n                  step=\"0.0001\"\n                  value={customer.latitude}\n                  onChange={(e) => handleCustomerChange(\"latitude\", parseFloat(e.target.value) || 0)}\n                  className=\"w-full bg-white border border-slate-200 rounded p-2 focus:bg-slate-50/50 font-mono tracking-wide outline-none focus:border-slate-400\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-[9px] font-mono text-slate-400 uppercase tracking-wider mb-1 font-bold\">\n                  Longitude Koordinat\n                </label>\n                <input\n                  type=\"number\"\n                  step=\"0.0001\"\n                  value={customer.longitude}\n                  onChange={(e) => handleCustomerChange(\"longitude\", parseFloat(e.target.value) || 0)}\n                  className=\"w-full bg-white border border-slate-200 rounded p-2 focus:bg-slate-50/50 font-mono tracking-wide outline-none focus:border-slate-400\"\n                />\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* Profiles Panel */}\n        {activeTab === \"profiles\" && (\n          <div className=\"space-y-3\">\n            <div className=\"flex items-center justify-between mb-1\">\n              <span className=\"text-slate-500 leading-normal text-[11px]\">\n                Kelola metadata profil beban kerja harian kolektor:\n              </span>\n              <button\n                onClick={handleAddProfile}\n                className=\"flex items-center gap-1 bg-slate-800 hover:bg-slate-900 text-white font-bold px-2 py-1 rounded transition-colors text-[10px]\"\n                id=\"btn-add-profile\"\n              >\n                <Plus className=\"w-3.5 h-3.5\" />\n                Tambah Kolektor\n              </button>\n            </div>\n\n            {profiles.length === 0 ? (\n              <div className=\"p-4 bg-slate-50 border border-dashed border-slate-250 rounded text-slate-500 text-center\">\n                Belum ada data kolektor. Tambahkan kolektor atau load sampel.\n              </div>\n            ) : (\n              <div className=\"space-y-2 max-h-[220px] overflow-auto pr-1\">\n                {profiles.map((prof, pIdx) => (\n                  <div\n                    key={pIdx}\n                    className=\"p-3 bg-white rounded border border-slate-200 flex flex-col gap-2 relative group\"\n                  >\n                    <button\n                      onClick={() => handleDeleteProfile(pIdx)}\n                      className=\"absolute top-2 right-2 text-slate-400 hover:text-red-600 p-1 rounded hover:bg-slate-100 transition-colors opacity-0 group-hover:opacity-100\"\n                      title=\"Hapus Profil\"\n                      id={`btn-del-profile-${pIdx}`}\n                    >\n                      <Trash2 className=\"w-3.5 h-3.5\" />\n                    </button>\n                    <div className=\"grid grid-cols-4 gap-2\">\n                      <div>\n                        <label className=\"block text-[8px] font-mono text-slate-400 mb-0.5 font-bold\">KODE</label>\n                        <input\n                          type=\"text\"\n                          value={prof.collector_code}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"collector_code\", e.target.value)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono font-bold outline-none\"\n                        />\n                      </div>\n                      <div>\n                        <label className=\"block text-[8px] font-mono text-slate-400 mb-0.5 font-bold font-mono\">NASABAH</label>\n                        <input\n                          type=\"number\"\n                          value={prof.active_customers}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"active_customers\", parseInt(e.target.value) || 0)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono outline-none\"\n                        />\n                      </div>\n                      <div className=\"col-span-2\">\n                        <label className=\"block text-[8px] font-mono text-slate-400 mb-0.5 font-bold\">NOMI. (Rp)</label>\n                        <input\n                          type=\"number\"\n                          value={prof.total_nominal}\n                          onChange={(e) => handleUpdateProfile(pIdx, \"total_nominal\", parseInt(e.target.value) || 0)}\n                          className=\"w-full bg-white border border-slate-200 rounded p-1 text-[10px] font-mono outline-none\"\n                        />\n                      </div>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        )}\n\n        {/* Raw JSON import/export panel */}\n        {activeTab === \"raw_json\" && (\n          <div className=\"space-y-3\">\n            <p className=\"text-slate-500 leading-normal text-[11px]\">\n              Gunakan editor JSON di bawah untuk memproses tumpukan database yang kompleks sekaligus:\n            </p>\n            <textarea\n              value={rawText}\n              onChange={(e) => setRawText(e.target.value)}\n              rows={8}\n              className=\"w-full bg-slate-900 border border-slate-800 text-slate-100 rounded p-3 font-mono text-[10px] leading-relaxed resize-y focus:outline-none focus:ring-1 focus:ring-slate-700\"\n              placeholder=\"Masukkan JSON murni berisi data customer, profiles, dan activities\"\n            />\n            {jsonError && (\n              <div className=\"p-2.5 bg-red-50 border border-red-150 rounded text-red-700 flex items-start gap-1.5 leading-relaxed text-[10px]\">\n                <AlertTriangle className=\"w-3.5 h-3.5 flex-shrink-0 mt-0.5\" />\n                <span>Error: {jsonError}</span>\n              </div>\n            )}\n            <div className=\"flex gap-2 justify-end\">\n              <button\n                onClick={() => setRawText(JSON.stringify({ customer, profiles, activities }, null, 2))}\n                className=\"px-2.5 py-1.5 border border-slate-200 rounded text-slate-600 hover:bg-slate-50 transition-colors font-medium text-[10.5px]\"\n                id=\"btn-sync-raw\"\n              >\n                Sinkronkan dengan Layar\n              </button>\n              <button\n                onClick={handleRawSubmit}\n                className=\"px-3 py-1.5 bg-slate-800 hover:bg-slate-900 text-white rounded font-bold transition-colors text-[10.5px]\"\n                id=\"btn-apply-raw\"\n              >\n                Terapkan Data\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* Summary Footer bar */}\n      <div className=\"p-3 bg-slate-50/50 border-t border-slate-200 flex items-center justify-between text-[11px] text-slate-450 font-mono\">\n        <span className=\"font-bold text-slate-500 text-[10px] uppercase\">Database Status</span>\n        <span className=\"text-slate-650 font-medium\">\n          {profiles.length} Profil Kolektor | {activities.length} Aktivitas GPS\n        </span>\n      </div>\n    </div>\n  );"
