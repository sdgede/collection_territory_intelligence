steps {
  type: CORTEX_STEP_TYPE_USER_INPUT
  status: CORTEX_STEP_STATUS_DONE
  metadata {
    created_at {
      seconds: 1781931849
      nanos: 302481627
    }
    source: CORTEX_STEP_SOURCE_USER_EXPLICIT
    source_trajectory_step_info {
      trajectory_id: "46baee30-b6c3-4cd7-9e2d-f4ce837f7dfa"
      step_index: 1
      cascade_id: "46baee30-b6c3-4cd7-9e2d-f4ce837f7dfa"
