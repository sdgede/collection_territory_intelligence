          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (isColdStart) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return `Kolektor ${code} direkomendasikan sementara di peringkat ${rank} murni berdasarkan jarak terdekat garis lurus sebesar ${dist} km dari lokasi nasabah (situasi Cold Start harian).`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (rank === 1) {"
