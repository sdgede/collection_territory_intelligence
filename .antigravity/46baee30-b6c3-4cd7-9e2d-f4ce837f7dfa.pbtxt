    replacement_chunks {
      target_content: "  return (\n    <div className=\"min-h-screen bg-slate-50 flex flex-col font-sans\" id=\"app-root-container\">\n      {/* Top Professional Executive Header */}\n      <header className=\"bg-slate-900 border-b border-slate-800 text-white px-6 py-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4\" id=\"ctis-header\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"p-2.5 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl shadow-md flex items-center justify-center text-white\" id=\"app-brand-logo\">\n            <Cpu className=\"w-5 h-5\" />\n          </div>\n          <div>\n            <h1 className=\"font-display font-bold text-lg tracking-tight text-white flex items-center gap-2\">\n              Collection Territory Intelligence System\n              <span className=\"text-[10px] bg-blue-600/30 border border-blue-500/40 text-blue-400 px-1.5 py-0.5 rounded font-mono font-semibold tracking-wide uppercase select-none\">\n                v2.1\n              </span>\n            </h1>\n            <p className=\"text-xs text-slate-400 leading-none mt-1\">\n              Sistem Analisis Spasial Dan Rekomendasi Teritori Penugasan Kolektor Terbaik\n            </p>\n          </div>\n        </div>\n        <div className=\"flex items-center gap-3 self-stretch md:self-auto justify-between border-t border-slate-800 pt-3 md:pt-0 md:border-0 font-mono text-[10px] text-slate-400\">\n          <div className=\"text-left md:text-right\">\n            <div>LOGIN: <span className=\"text-slate-200\">gedeindrawan2006@gmail.com</span></div>\n            <div>WAKTU: <span className=\"text-slate-200\">2026-06-19 22:04:09 UTC</span></div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <main className=\"flex-1 p-6 max-w-7xl w-full mx-auto flex flex-col gap-6\" id=\"dashboard-main-view\">\n        \n        {/* Core Bento Grid layout */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n          \n          {/* COLUMN 1: Ingestion & Configurations */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6 h-full\">\n            <DataImporter\n              customer={customer}\n              profiles={profiles}\n              activities={activities}\n              onChangeData={handleUpdateAllData}\n              referenceDate={referenceDate}\n              onChangeReferenceDate={(val) => {\n                setReferenceDate(val);\n                setApiMode(false);\n              }}\n            />\n\n            {/* AI Generator Trigger Card with prompt-guidelines logic */}\n            <div className=\"bg-white rounded-2xl border border-blue-100 p-5 shadow-sm flex flex-col gap-3 relative overflow-hidden\" id=\"ai-trigger-banner\">\n              <div className=\"absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-full transform translate-x-6 -translate-y-6\" />\n              <div className=\"flex items-start gap-3\">\n                <div className=\"p-2 bg-blue-50 rounded-xl text-blue-600\">\n                  <Sparkles className=\"w-4 h-4\" />\n                </div>\n                <div>\n                  <h4 className=\"font-semibold text-slate-800 text-xs\">Asisten Kecerdasan Buatan (Gemini AI)</h4>\n                  <p className=\"text-[10px] text-slate-500 mt-1 leading-relaxed\">\n                    Tingkatkan hasil komparasi spasial dengan deskripsi analisis risiko dan ringkasan manajemen yang dibuat personal oleh Gemini 3.5 Flash.\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"flex items-center justify-between mt-1 pt-2 border-t border-slate-100\">\n                <span className=\"text-[9px] text-slate-400 font-mono\">\n                  {apiMode ? \"Mode: Gemini AI Aktif\" : \"Mode: Algoritma Lokal\"}\n                </span>\n                <button\n                  onClick={queryServerAnalysis}\n                  disabled={aiLoading}\n                  className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[10px] font-semibold tracking-wide uppercase shadow-sm transition-all ${\n                    aiLoading\n                      ? \"bg-slate-150 text-slate-400 border border-slate-200 cursor-not-allowed\"\n                      : \"bg-blue-600 hover:bg-blue-700 hover:shadow text-white cursor-pointer\"\n                  }`}\n                  id=\"btn-trigger-ai\"\n                >\n                  {aiLoading ? (\n                    <>\n                      <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                      <span>Memproses...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-3.5 h-3.5\" />\n                      <span>{apiMode ? \"Segarkan Analisis\" : \"Tingkatkan Analisis\"}</span>\n                    </>\n                  )}\n                </button>\n              </div>\n            </div>\n          </div>\n\n          {/* COLUMN 2: Map & Collectors Matching */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6\">\n            <div className=\"flex-1 min-h-[360px]\">\n              <InteractiveMap\n                customer={customer}\n                activities={activities}\n                selectedCollectorCode={selectedCollectorCode}\n                onSelectCollector={setSelectedCollectorCode}\n              />\n            </div>\n\n            {/* List of Sorted Candidates */}\n            <div className=\"flex flex-col gap-3\">\n              <div className=\"flex items-center justify-between px-1\">\n                <h3 className=\"font-display font-semibold text-slate-800 text-xs tracking-wide\">\n                  Hasil Komparasi Matchmaking ({profiles.length} Kolektor)\n                </h3>\n                <span className=\"text-[9px] text-slate-400 font-mono uppercase\">\n                  Dibersihkan dari GPS Noise\n                </span>\n              </div>\n              <div className=\"space-y-3.5 max-h-[300px] overflow-auto pr-1 flex flex-col\">\n                {analysisReport.top_collectors.map((col) => (\n                  <div key={col.collector_code}>\n                    <CollectorCard\n                      collector={col}\n                      isSelected={selectedCollectorCode === col.collector_code}\n                      onSelect={() =>\n                        setSelectedCollectorCode(\n                          selectedCollectorCode === col.collector_code ? null : col.collector_code\n                        )\n                      }\n                    />\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n\n          {/* COLUMN 3: Management Reports & API Endpoint */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6 justify-between h-full\">\n            {/* Analysis report outputs */}\n            <div className=\"bg-white rounded-2xl border border-slate-150 p-5 shadow-sm flex flex-col gap-4 text-left\" id=\"management-report-card\">\n              <div className=\"border-b border-slate-100 pb-3 flex items-center justify-between\">\n                <div>\n                  <h3 className=\"font-display font-bold text-slate-900 text-sm\">\n                    Tinjauan Analitis Teritori\n                  </h3>\n                  <p className=\"text-[10px] text-slate-400 font-mono mt-0.5\">\n                    DIANALISIS PADA {analysisReport.analysis_period}\n                  </p>\n                </div>\n                <Bookmark className=\"w-4 h-4 text-slate-400\" />\n              </div>\n\n              {/* Executive summary block */}\n              <div className=\"flex flex-col gap-1.5\">\n                <span className=\"text-[9px] text-slate-400 font-mono tracking-wider uppercase font-semibold\">\n                  Executive Summary\n                </span>\n                <p className=\"text-slate-700 text-xs leading-relaxed font-sans font-normal\" id=\"exec-summary-text\">\n                  {analysisReport.executive_summary}\n                </p>\n              </div>\n\n              {/* Focus target actions block */}\n              <div className=\"flex flex-col gap-2 pt-3 border-t border-slate-100\">\n                <span className=\"text-[9px] text-slate-400 font-mono tracking-wider uppercase font-semibold flex items-center gap-1\">\n                  <CheckSquare className=\"w-3.5 h-3.5 text-blue-500\" />\n                  Rekomendasi Tindakan Operasional\n                </span>\n                <ul className=\"space-y-1.5\" id=\"actions-list\">\n                  {analysisReport.recommended_actions.map((act, index) => (\n                    <li key={index} className=\"text-[11px] text-slate-700 flex items-start gap-1.5 leading-relaxed\">\n                      <span className=\"text-emerald-500 text-xs font-bold leading-none mt-0.5\">\342\200\242</span>\n                      <span>{act}</span>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n\n              {/* Risks and constraints warnings block */}\n              <div className=\"flex flex-col gap-2 pt-3 border-t border-slate-100\">\n                <span className=\"text-[9px] text-slate-400 font-mono tracking-wider uppercase font-semibold flex items-center gap-1\">\n                  <ShieldAlert className=\"w-3.5 h-3.5 text-amber-500\" />\n                  Analisis Risiko Spasial\n                </span>\n                <div className=\"space-y-1.5\" id=\"risks-list\">\n                  {analysisReport.risk_analysis.length === 0 ? (\n                    <p className=\"text-[11px] text-slate-500 italic font-sans pl-1\">\n                      Tidak terdeteksi deviasi risiko krusial untuk rancangan wilayah saat ini.\n                    </p>\n                  ) : (\n                    analysisReport.risk_analysis.map((risk, idx) => (\n                      <div key={idx} className=\"bg-amber-50/50 border border-amber-100 rounded-lg p-2 flex items-start gap-2 text-[10px] text-amber-900 leading-relaxed\">\n                        <AlertTriangle className=\"w-3.5 h-3.5 text-amber-500 flex-shrink-0 mt-0.5\" />\n                        <span>{risk}</span>\n                      </div>\n                    ))\n                  )}\n                </div>\n              </div>\n\n              {/* Data limitations warnings block */}\n              {analysisReport.data_limitations && analysisReport.data_limitations.length > 0 && (\n                <div className=\"flex flex-col gap-1.5 pt-3 border-t border-slate-100\">\n                  <span className=\"text-[8px] text-slate-400 font-mono tracking-wider uppercase font-semibold\">\n                    Keterbatasan Data Valid (Data Limitations)\n                  </span>\n                  <ul className=\"space-y-1\" id=\"limitations-list\">\n                    {analysisReport.data_limitations.map((limit, idx) => (\n                      <li key={idx} className=\"text-[10px] text-slate-500 leading-relaxed font-sans italic pl-1 flex items-start gap-1\">\n                        <span>-</span>\n                        <span>{limit}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n              )}\n            </div>\n\n            {/* Strict JSON output panel */}\n            <div className=\"flex-1\">\n              <JSONOutput output={analysisReport} />\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Humble Footer Block */}\n      <footer className=\"bg-slate-900 border-t border-slate-800 py-4 px-6 text-center text-[10px] text-slate-500 font-mono flex flex-col sm:flex-row items-center justify-between gap-2 mt-auto\" id=\"ctis-footer\">\n        <span>\302\251 2026 Collection Territory Intelligence System. Hak Cipta Dilindungi Undang-Undang.</span>\n        <span className=\"flex items-center gap-1\">\n          Dibuat murni menggunakan geocoding terverifikasi & Haversine.\n        </span>\n      </footer>\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"min-h-screen bg-slate-50/50 flex flex-col font-sans\" id=\"app-root-container\">\n      {/* Top Professional Executive Header - Clean Minimalism */}\n      <header className=\"bg-white border-b border-slate-200 px-6 py-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4\" id=\"ctis-header\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-8 h-8 bg-slate-800 rounded flex items-center justify-center text-white font-bold text-sm shadow-xs\" id=\"app-brand-logo\">\n            C\n          </div>\n          <div>\n            <h1 className=\"text-base font-bold tracking-tight uppercase text-slate-800 flex items-center gap-2\">\n              Collection Territory Intelligence System\n              <span className=\"text-[10px] bg-slate-100 border border-slate-200 text-slate-500 px-1.5 py-0.5 rounded font-mono font-medium tracking-wide uppercase normal-case\">\n                v2.1\n              </span>\n            </h1>\n            <p className=\"text-xs text-slate-500 mt-1\">\n              Sistem Analisis Spasial Dan Rekomendasi Teritori Penugasan Kolektor Terbaik\n            </p>\n          </div>\n        </div>\n        <div className=\"text-left md:text-right\">\n          <p className=\"text-[9px] uppercase tracking-widest text-slate-400 font-bold\">OPERATOR / UTC TIME</p>\n          <p className=\"text-xs font-mono text-slate-600 mt-0.5\">gedeindrawan2006@gmail.com</p>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <main className=\"flex-1 p-6 max-w-7xl w-full mx-auto flex flex-col gap-6\" id=\"dashboard-main-view\">\n        \n        {/* Core Bento Grid layout */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n          \n          {/* COLUMN 1: Ingestion & Configurations */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6 h-full\">\n            <DataImporter\n              customer={customer}\n              profiles={profiles}\n              activities={activities}\n              onChangeData={handleUpdateAllData}\n              referenceDate={referenceDate}\n              onChangeReferenceDate={(val) => {\n                setReferenceDate(val);\n                setApiMode(false);\n              }}\n            />\n\n            {/* AI Generator Trigger Card with Clean Minimalism theme */}\n            <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs flex flex-col gap-3 relative overflow-hidden\" id=\"ai-trigger-banner\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"p-2 bg-slate-100 rounded text-slate-700\">\n                  <Sparkles className=\"w-4 h-4\" />\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-slate-800 text-xs uppercase tracking-wider\">Asisten Kecerdasan Buatan (Gemini AI)</h4>\n                  <p className=\"text-[11px] text-slate-500 mt-1.5 leading-relaxed\">\n                    Tingkatkan hasil komparasi spasial dengan deskripsi analisis risiko dan ringkasan manajemen yang dibuat personal oleh Gemini 3.5 Flash.\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"flex items-center justify-between mt-2 pt-3 border-t border-slate-100\">\n                <span className=\"text-[10px] text-slate-400 font-mono\">\n                  {apiMode ? \"Mode: Gemini AI Aktif\" : \"Mode: Algoritma Lokal\"}\n                </span>\n                <button\n                  onClick={queryServerAnalysis}\n                  disabled={aiLoading}\n                  className={`flex items-center gap-1.5 px-3 py-1.5 rounded text-[10px] uppercase font-bold tracking-wider shadow-xs transition-all ${\n                    aiLoading\n                      ? \"bg-slate-100 text-slate-450 border border-slate-200 cursor-not-allowed\"\n                      : \"bg-slate-800 hover:bg-slate-900 text-white cursor-pointer\"\n                  }`}\n                  id=\"btn-trigger-ai\"\n                >\n                  {aiLoading ? (\n                    <>\n                      <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                      <span>Memproses...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-3.5 h-3.5\" />\n                      <span>{apiMode ? \"Segarkan Analisis\" : \"Tingkatkan Analisis\"}</span>\n                    </>\n                  )}\n                </button>\n              </div>\n            </div>\n          </div>\n\n          {/* COLUMN 2: Map & Collectors Matching */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6\">\n            <div className=\"flex-1 min-h-[360px]\">\n              <InteractiveMap\n                customer={customer}\n                activities={activities}\n                selectedCollectorCode={selectedCollectorCode}\n                onSelectCollector={setSelectedCollectorCode}\n              />\n            </div>\n\n            {/* List of Sorted Candidates */}\n            <div className=\"flex flex-col gap-3\">\n              <div className=\"flex items-center justify-between px-1\">\n                <h3 className=\"text-[11px] uppercase tracking-wider text-slate-400 font-bold\">\n                  Hasil Komparasi Matchmaking ({profiles.length} Kolektor)\n                </h3>\n                <span className=\"text-[9px] text-slate-400 font-mono uppercase\">\n                  Dibersihkan dari GPS Noise\n                </span>\n              </div>\n              <div className=\"space-y-3 max-h-[320px] overflow-auto pr-1 flex flex-col\">\n                {analysisReport.top_collectors.map((col) => (\n                  <div key={col.collector_code}>\n                    <CollectorCard\n                      collector={col}\n                      isSelected={selectedCollectorCode === col.collector_code}\n                      onSelect={() =>\n                        setSelectedCollectorCode(\n                          selectedCollectorCode === col.collector_code ? null : col.collector_code\n                        )\n                      }\n                    />\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n\n          {/* COLUMN 3: Management Reports & API Endpoint */}\n          <div className=\"lg:col-span-4 flex flex-col gap-6 justify-between h-full\">\n            {/* Analysis report outputs - Clean Minimalism */}\n            <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs flex flex-col gap-4 text-left\" id=\"management-report-card\">\n              <div className=\"border-b border-slate-100 pb-3 flex items-center justify-between\">\n                <div>\n                  <h3 className=\"text-[11px] uppercase tracking-wider text-slate-400 font-bold\">\n                    Tinjauan Analitis Teritori\n                  </h3>\n                  <p className=\"text-[9px] text-slate-400 font-mono mt-0.5 uppercase\">\n                    Periode analisis: {analysisReport.analysis_period}\n                  </p>\n                </div>\n                <Bookmark className=\"w-4 h-4 text-slate-400\" />\n              </div>\n\n              {/* Executive summary block */}\n              <div className=\"flex flex-col gap-1.5\">\n                <span className=\"text-[10px] uppercase tracking-widest text-slate-400 font-bold\">\n                  Executive Summary\n                </span>\n                <p className=\"text-slate-650 text-xs leading-relaxed text-slate-600\" id=\"exec-summary-text\">\n                  {analysisReport.executive_summary}\n                </p>\n              </div>\n\n              {/* Recommended Action steps block */}\n              <div className=\"flex flex-col gap-2 pt-3 border-t border-slate-100\">\n                <span className=\"text-[10px] uppercase tracking-widest text-slate-400 font-bold flex items-center gap-1\">\n                  <CheckSquare className=\"w-3.5 h-3.5 text-slate-500\" />\n                  Recommended Actions\n                </span>\n                <div className=\"space-y-1.5\" id=\"actions-list\">\n                  {analysisReport.recommended_actions.map((act, index) => (\n                    <div key={index} className=\"p-2 bg-slate-50 border border-slate-200/60 rounded text-[11px] text-slate-700\">\n                      {act}\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              {/* Risks and constraints warnings block */}\n              <div className=\"flex flex-col gap-2 pt-3 border-t border-slate-100\">\n                <span className=\"text-[10px] uppercase tracking-widest text-slate-400 font-bold flex items-center gap-1\">\n                  <ShieldAlert className=\"w-3.5 h-3.5 text-slate-500\" />\n                  Risk Analysis\n                </span>\n                <div className=\"space-y-1.5\" id=\"risks-list\">\n                  {analysisReport.risk_analysis.length === 0 ? (\n                    <p className=\"text-[11px] text-slate-450 italic pl-1\">\n                      Tidak terdeteksi deviasi risiko krusial untuk rancangan wilayah saat ini.\n                    </p>\n                  ) : (\n                    analysisReport.risk_analysis.map((risk, idx) => (\n                      <div key={idx} className=\"flex gap-2 text-xs text-slate-600\">\n                        <span className=\"text-amber-500\">\342\227\217</span>\n                        <span>{risk}</span>\n                      </div>\n                    ))\n                  )}\n                </div>\n              </div>\n\n              {/* Data limitations warnings block */}\n              {analysisReport.data_limitations && analysisReport.data_limitations.length > 0 && (\n                <div className=\"flex flex-col gap-1.5 pt-3 border-t border-slate-100\">\n                  <span className=\"text-[9px] uppercase tracking-wider text-slate-450 font-semibold font-mono\">\n                    Data Limitations\n                  </span>\n                  <ul className=\"space-y-1\" id=\"limitations-list\">\n                    {analysisReport.data_limitations.map((limit, idx) => (\n                      <li key={idx} className=\"text-[10px] text-slate-500 leading-relaxed italic pl-1 flex items-start gap-1\">\n                        <span>-</span>\n                        <span>{limit}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n              )}\n            </div>\n\n            {/* Strict JSON output panel */}\n            <div className=\"flex-1\">\n              <JSONOutput output={analysisReport} />\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Humble Footer Block - Clean Minimalism */}\n      <footer className=\"bg-white border-t border-slate-200 px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 mt-auto text-[10px] text-slate-400 font-medium\" id=\"ctis-footer\">\n        <span>\302\251 2026 TERRITORY INTELLIGENCE ENGINE v2.4</span>\n        <span className=\"flex items-center gap-1 uppercase tracking-wider\">\n          Data Confidentiality Level: Internal Only\n        </span>\n      </footer>\n    </div>\n  );"
