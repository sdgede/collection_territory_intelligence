    tool_summary: "Create InteractiveMap.tsx"
    tool_action: "Creating Interactive Map component"
    started_at {
      seconds: 1781932083
      nanos: 97782940
    }
  }
  file_change {
    absolute_path_uri: "file:///src/components/InteractiveMap.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \"react\";\nimport { Customer, CollectorActivity } from \"../types\";\nimport { MapPin, ZoomIn, ZoomOut, Compass, Info } from \"lucide-react\";\n\ninterface InteractiveMapProps {\n  customer: Customer;\n  activities: CollectorActivity[];\n  selectedCollectorCode: string | null;\n  onSelectCollector: (code: string | null) => void;\n}\n\nexport default function InteractiveMap({\n  customer,\n  activities,\n  selectedCollectorCode,\n  onSelectCollector,\n}: InteractiveMapProps) {\n  const [zoomLevel, setZoomLevel] = useState<number>(3.8); // radius in km represented on screen\n\n  // Filter activities to ignore extreme anomalies for the map display\n  const mapActivities = activities.filter(\n    (act) =>\n      Math.abs(act.latitude - customer.latitude) < 2.0 &&\n      Math.abs(act.longitude - customer.longitude) < 2.0\n  );\n\n  // Map collector codes to robust, distinct theme colors (Tailwind & Hex style)\n  const getCollectorColors = (code: string) => {\n    const hash = code.split(\"\").reduce((acc, char) => acc + char.charCodeAt(0), 0);\n    const index = hash % 5;\n    const schemes = [\n      { border: \"#3b82f6\", fill: \"#93c5fd\", text: \"text-blue-600\", bg: \"bg-blue-500\", rawBg: \"#3b82f6\" },\n      { border: \"#eab308\", fill: \"#fef08a\", text: \"text-yellow-600\", bg: \"bg-yellow-500\", rawBg: \"#eab308\" },\n      { border: \"#a855f7\", fill: \"#e9d5ff\", text: \"text-purple-600\", bg: \"bg-purple-500\", rawBg: \"#a855f7\" },\n      { border: \"#06b6d4\", fill: \"#a5f3fc\", text: \"text-cyan-600\", bg: \"bg-cyan-500\", rawBg: \"#06b6d4\" },\n      { border: \"#f43f5e\", fill: \"#fecdd3\", text: \"text-rose-600\", bg: \"bg-rose-500\", rawBg: \"#f43f5e\" },\n    ];\n    return schemes[index];\n  };\n\n  // Map coordinates to SVG dimensions (width=500, height=400)\n  // 1 degree of Latitude is approx 111.12 km\n  // 1 degree of Longitude is approx 111.12 * cos(lat) km\n  const getSvgCoords = (lat: number, lng: number) => {\n    const latDiff = lat - customer.latitude;\n    const lngDiff = lng - customer.longitude;\n\n    const latScale = zoomLevel / 111.12;\n    const lngScale = zoomLevel / (111.12 * Math.cos((customer.latitude * Math.PI) / 180));\n\n    const dy = latDiff / latScale; // range [-1, 1]\n    const dx = lngDiff / lngScale; // range [-1, 1]\n\n    // Width = 500 (cx = 250), Height = 400 (cy = 200). Scale factor 180 to fit comfortable padding\n    const x = 250 + dx * 180;\n    const y = 200 - dy * 180; // invert Y for screen space\n\n    return { x, y };\n  };\n\n  const cCoords = { x: 250, y: 200 };\n\n  // Convert distance in km to SVG radius pixels\n  const getSvgRadius = (km: number) => {\n    return (km / zoomLevel) * 180;\n  };\n\n  const r1Pixels = getSvgRadius(1.0);\n  const r3Pixels = getSvgRadius(3.0);\n\n  // Group activities to count them per collector\n  const collectorsInDataset = Array.from(new Set(activities.map((a) => a.collector_code)));\n\n  const handleZoom = (direction: \"in\" | \"out\") => {\n    setZoomLevel((prev) => {\n      if (direction === \"in\") return Math.max(1.0, prev * 0.7);\n      return Math.min(60.0, prev * 1.4);\n    });\n  };\n\n  return (\n    <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col h-full\" id=\"map-section-card\">\n      <div className=\"p-4 bg-slate-50 border-b border-slate-100 flex items-center justify-between\">\n        <div>\n          <h3 className=\"font-display font-semibold text-slate-800 text-sm flex items-center gap-2\">\n            <Compass className=\"w-4 h-4 text-slate-500\" />\n            Visualisasi Spasial Wilayah Operasional\n          </h3>\n          <p className=\"text-xs text-slate-500 mt-0.5\">\n            Menampilkan radius wilayah inti (1 km) dan sekunder (3 km) serta jejak aktivitas kolektor.\n          </p>\n        </div>\n        <div className=\"flex items-center gap-1\">\n          <button\n            onClick={() => handleZoom(\"in\")}\n            className=\"p-1.5 hover:bg-slate-200 active:bg-slate-300 text-slate-600 rounded-lg transition-colors\"\n            title=\"Perbesar Peta\"\n            id=\"btn-zoom-in\"\n          >\n            <ZoomIn className=\"w-4 h-4\" />\n          </button>\n          <button\n            onClick={() => handleZoom(\"out\")}\n            className=\"p-1.5 hover:bg-slate-200 active:bg-slate-300 text-slate-600 rounded-lg transition-colors\"\n            title=\"Perkecil Peta\"\n            id=\"btn-zoom-out\"\n          >\n            <ZoomOut className=\"w-4 h-4\" />\n          </button>\n          <button\n            onClick={() => setZoomLevel(3.8)}\n            className=\"px-2 py-1 text-[10px] bg-white border border-slate-200 font-mono text-slate-600 hover:bg-slate-50 rounded-md shadow-sm transition-colors\"\n            title=\"Reset Zoom\"\n            id=\"btn-zoom-reset\"\n          >\n            {zoomLevel.toFixed(1)} km\n          </button>\n        </div>\n      </div>\n\n      <div className=\"relative flex-1 bg-slate-950 flex items-center justify-center min-h-[340px]\">\n        {/* SVG Drawing Canvas */}\n        <svg\n          viewBox=\"0 0 500 400\"\n          className=\"w-full h-full select-none\"\n          id=\"svg-map-canvas\"\n        >\n          {/* Circular Grid Lines for aesthetic feel */}\n          <circle cx=\"250\" cy=\"200\" r=\"10\" fill=\"none\" stroke=\"#334155\" strokeWidth=\"0.5\" />\n          <line x1=\"250\" y1=\"0\" x2=\"250\" y2=\"400\" stroke=\"#1e293b\" strokeWidth=\"0.5\" strokeDasharray=\"3\" />\n          <line x1=\"0\" y1=\"200\" x2=\"500\" y2=\"200\" stroke=\"#1e293b\" strokeWidth=\"0.5\" strokeDasharray=\"3\" />\n\n          {/* RADIUS SEKURNDER (3.0 km) Circle */}\n          <circle\n            cx=\"250\"\n            cy=\"200\"\n            r={r3Pixels}\n            fill=\"#eab308\"\n            fillOpacity=\"0.03\"\n            stroke=\"#eab308\"\n            strokeWidth=\"1.5\"\n            strokeDasharray=\"4 4\"\n          />\n\n          {/* RADIUS INTI (1.0 km) Circle */}\n          <circle\n            cx=\"250\"\n            cy=\"200\"\n            r={r1Pixels}\n            fill=\"#10b981\"\n            fillOpacity=\"0.05\"\n            stroke=\"#10b981\"\n            strokeWidth=\"1.5\"\n            strokeDasharray=\"4 4\"\n          />\n\n          {/* Radius text annotations */}\n          {r1Pixels > 40 && (\n            <text\n              x={250}\n              y={200 - r1Pixels + 12}\n              fill=\"#10b981\"\n              fontSize=\"9\"\n              fontWeight=\"600\"\n              textAnchor=\"middle\"\n              className=\"font-mono bg-slate-900\"\n            >\n              Cakupan Inti (1 km)\n            </text>\n          )}\n\n          {r3Pixels > 60 && (\n            <text\n              x={250}\n              y={200 - r3Pixels + 12}\n              fill=\"#eab308\"\n              fontSize=\"9\"\n              fontWeight=\"600\"\n              textAnchor=\"middle\"\n              className=\"font-mono\"\n            >\n              Koridor Sekunder (3 km)\n            </text>\n          )}\n\n          {/* Draw connecting lines if a collector is selected for route tracking */}\n          {mapActivities.map((act, index) => {\n            if (selectedCollectorCode && act.collector_code !== selectedCollectorCode) return null;\n            const actCoords = getSvgCoords(act.latitude, act.longitude);\n\n            // Ignore extreme bounds\n            if (\n              actCoords.x < 0 ||\n              actCoords.x > 500 ||\n              actCoords.y < 0 ||\n              actCoords.y > 400\n            ) {\n              return null;\n            }\n\n            const colors = getCollectorColors(act.collector_code);\n            return (\n              <line\n                key={`line-${index}`}\n                x1={250}\n                y1={200}\n                x2={actCoords.x}\n                y2={actCoords.y}\n                stroke={colors.border}\n                strokeWidth={selectedCollectorCode ? \"1.5\" : \"0.5\"}\n                strokeOpacity={selectedCollectorCode ? \"0.6\" : \"0.2\"}\n                strokeDasharray={selectedCollectorCode ? undefined : \"2 2\"}\n              />\n            );\n          })}\n\n          {/* Collector Activity Pins */}\n          {mapActivities.map((act, index) => {\n            const isSelected = selectedCollectorCode === act.collector_code;\n            const actCoords = getSvgCoords(act.latitude, act.longitude);\n\n            // Filter points clipped outside screen\n            if (\n              actCoords.x < 0 ||\n              actCoords.x > 500 ||\n              actCoords.y < 0 ||\n              actCoords.y > 400\n            ) {\n              return null;\n            }\n\n            const colors = getCollectorColors(act.collector_code);\n            const dist = Math.sqrt(\n              Math.pow(actCoords.x - 250, 2) + Math.pow(actCoords.y - 200, 2)\n            );\n\n            return (\n              <g\n                key={`act-${index}`}\n                className=\"cursor-pointer transition-all duration-200\"\n                onClick={() =>\n                  onSelectCollector(\n                    selectedCollectorCode === act.collector_code\n                      ? null\n                      : act.collector_code\n                  )\n                }\n                opacity={\n                  !selectedCollectorCode || isSelected ? 1 : 0.25\n                }\n              >\n                {/* Background ring for active item */}\n                {isSelected && (\n                  <circle\n                    cx={actCoords.x}\n                    cy={actCoords.y}\n                    r=\"8\"\n                    fill=\"none\"\n                    stroke={colors.border}\n                    strokeWidth=\"1\"\n                    className=\"animate-ping\"\n                  />\n                )}\n                {/* Visual pin on coordinate */}\n                <circle\n                  cx={actCoords.x}\n                  cy={actCoords.y}\n                  r={isSelected ? \"5\" : \"4\"}\n                  fill={colors.fill}\n                  stroke={colors.border}\n                  strokeWidth=\"2\"\n                />\n                <title>{`Kolektor ${act.collector_code} | ${act.activity_description} | Rp ${act.transaction_amount.toLocaleString(\"id-ID\")}`}</title>\n              </g>\n            );\n          })}\n\n          {/* Customer pulsing central anchor */}\n          <g transform=\"translate(250, 200)\">\n            <circle cx=\"0\" cy=\"0\" r=\"14\" fill=\"#ef4444\" fillOpacity=\"0.15\" className=\"animate-pulse\" />\n            <circle cx=\"0\" cy=\"0\" r=\"6\" fill=\"#ef4444\" stroke=\"#ffffff\" strokeWidth=\"2\" />\n            <path d=\"M-3 -3 L3 3 M-3 3 L3 -3\" stroke=\"#ffffff\" strokeWidth=\"1\" />\n          </g>\n        </svg>\n\n        {/* Legend Overlay */}\n        <div className=\"absolute bottom-3 left-3 bg-slate-900/95 backdrop-blur-sm border border-slate-800 text-white rounded-xl p-3 flex flex-col gap-2 max-w-[200px] shadow-lg\">\n          <div className=\"text-[10px] font-mono font-medium tracking-wider text-slate-400 border-b border-slate-800 pb-1 uppercase flex items-center justify-between\">\n            <span>Legenda Peta</span>\n            <Info className=\"w-3 h-3\" />\n          </div>\n          <div className=\"flex items-center gap-2 text-xs\">\n            <span className=\"w-2.5 h-2.5 rounded-full bg-red-500 border border-white flex-shrink-0 animate-pulse\" />\n            <div className=\"truncate font-medium text-slate-200 text-[11px]\" title={customer.customer_name}>\n              Nasabah: {customer.customer_name}\n            </div>\n          </div>\n          <div className=\"flex flex-col gap-1 mt-1 border-t border-slate-800/50 pt-2\">\n            <div className=\"text-[9px] text-slate-400 font-mono\">JEJAK KOLEKTOR:</div>\n            {collectorsInDataset.map((code) => {\n              const colors = getCollectorColors(code);\n              const isSelected = selectedCollectorCode === code;\n              return (\n                <button\n                  key={code}\n                  onClick={() => onSelectCollector(isSelected ? null : code)}\n                  className={`flex items-center gap-1.5 text-left rounded-md px-1.5 py-0.5 text-[10px] transition-colors ${\n                    isSelected ? \"bg-slate-800 text-white\" : \"text-slate-300 hover:bg-slate-800/50\"\n                  }`}\n                >\n                  <span\n                    className=\"w-2 h-2 rounded-full flex-shrink-0\"\n                    style={{ backgroundColor: colors.border }}\n                  />\n                  <span className=\"font-mono font-semibold\">{code}</span>\n                  {isSelected && <span className=\"text-[8px] bg-slate-700 px-1 rounded font-sans scale-90\">Aktif</span>}\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Floating current map coordinate info */}\n        <div className=\"absolute top-3 left-3 bg-slate-950/80 backdrop-blur-sm px-2.5 py-1.5 rounded-lg border border-slate-800 text-left font-mono text-[9px] text-slate-300\">\n          <div>LAT: {customer.latitude.toFixed(5)}</div>\n          <div>LNG: {customer.longitude.toFixed(5)}</div>\n        </div>\n      </div>\n\n      <div className=\"p-3 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-[11px] text-slate-500\">\n        <span className=\"flex items-center gap-1\">\n          <span className=\"w-2.5 h-2.5 rounded-full border border-dashed border-emerald-500 bg-emerald-500/10\" />\n          Area Inti (1km)\n        </span>\n        <span className=\"flex items-center gap-1\">\n          <span className=\"w-2.5 h-2.5 rounded-full border border-dashed border-yellow-500 bg-yellow-500/10\" />\n          Area Sekunder (1-3km)\n        </span>\n        <span className=\"font-mono text-[10px]\">\n          {mapActivities.length} dari {activities.length} aktivitas diplot\n        </span>\n      </div>\n    </div>\n  );\n}\n"
    }
