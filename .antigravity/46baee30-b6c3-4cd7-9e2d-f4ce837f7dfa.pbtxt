        }
        lines {
          text: "    if (count >= 10 && cv < 0.5) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return `Kolektor ${code} direkomendasikan utama karena sangat aktif dengan ${count} kunjungan di area ini, rata-rata jarak dekat ${dist} km, dan pola kehadiran mingguan yang konsisten tinggi (CV ${cv}).`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return `Kolektor ${code} direkomendasikan di posisi teratas berdasarkan frekuensi kunjungan harian sebanyak ${count} kali di sekitar lokasi nasabah dan jarak rata-rata optimal ${dist} km.`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (count > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return `Kolektor ${code} sebagai alternatif peringkat ${rank} dengan cakupan wilayah yang mencakup area nasabah (${count} aktivitas, rata-rata jarak ${dist} km), namun memiliki skor keterlibatan lebih rendah dibanding peringkat di atasnya.`;"
