        }
        lines {
          text: "      const timeDiff = actDate.getTime() - minTime;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const weekIdx = Math.min(totalWeeks - 1, Math.max(0, Math.floor(timeDiff / (7 * 24 * 60 * 60 * 1000))));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats.weeklyCounts[weekIdx] += 1;"
