    instruction: "Apply clean minimalism style to CollectorCard: clean slate-200 borders, minimal shadows, subtle focus states, and soft badge colors conforming to design principles."
    replacement_infos {
      original_chunk {
        target_content: "  const getRankStyle = (r: number) => {\n    if (r === 1) {\n      return {\n        card: \"bg-white border-amber-300 ring-2 ring-amber-400/10 shadow-md shadow-amber-500/5 hover:border-amber-400\",\n        badge: \"bg-amber-500 hover:bg-amber-600 text-white shadow-sm ring-2 ring-amber-100\",\n        icon: <Award className=\"w-4 h-4 text-amber-500\" />,\n      };\n    }\n    if (r === 2) {\n      return {\n        card: \"bg-white border-slate-300 shadow-sm hover:border-slate-400\",\n        badge: \"bg-slate-500 hover:bg-slate-600 text-white\",\n        icon: <Award className=\"w-4 h-4 text-slate-400\" />,\n      };\n    }\n    return {\n      card: \"bg-white border-slate-100 shadow-sm hover:border-slate-200\",\n      badge: \"bg-slate-400 text-white\",\n      icon: <User className=\"w-4 h-4 text-slate-400\" />,\n    };\n  };\n\n  const style = getRankStyle(rank);\n  const confStyle = getConfStyle(confidence);\n\n  return (\n    <div\n      onClick={onSelect}\n      className={`rounded-2xl border-2 p-5 transition-all duration-200 cursor-pointer flex flex-col gap-4 relative overflow-hidden text-left ${style.card} ${\n        isSelected ? \"ring-2 ring-blue-600/30 scale-[1.01]\" : \"\"\n      }`}\n      id={`collector-card-${collector_code}`}\n    >\n      {/* Top Banner Row */}\n      <div className=\"flex items-center justify-between\">\n        <div className=\"flex items-center gap-2.5\">\n          <span className={`w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold font-display ${style.badge}`} id={`badge-rank-${collector_code}`}>\n            {rank}\n          </span>\n          <div>\n            <h4 className=\"font-mono font-bold text-slate-900 tracking-wide text-sm flex items-center gap-1\">\n              Kolektor {collector_code}\n              {rank === 1 && <Sparkles className=\"w-3.5 h-3.5 text-amber-500 animate-pulse\" />}\n            </h4>\n            <div className=\"flex items-center gap-1.5 mt-0.5\">\n              {style.icon}\n              <span className=\"text-[10px] text-slate-400 uppercase font-mono tracking-wider font-semibold\">\n                Kandidat Terpilih {rank === 1 ? \"Utama\" : `Cadangan #${rank - 1}`}\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* Global score indicator */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"text-right\">\n            <div className=\"text-2xl font-display font-extrabold text-slate-900 leading-none\">\n              {score}\n              <span className=\"text-xs font-medium text-slate-400 ml-0.5\">/100</span>\n            </div>\n            <span className=\"text-[9px] text-slate-400 font-mono tracking-wider\">MATU. SCORE</span>\n          </div>\n          <div className=\"w-11 h-11 flex-shrink-0 relative\">\n            <svg viewBox=\"0 0 36 36\" className=\"w-full h-full transform -rotate-90\">\n              <path\n                d=\"M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831\"\n                fill=\"none\"\n                stroke=\"#f1f5f9\"\n                strokeWidth=\"3.5\"\n              />\n              <path\n                d=\"M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831\"\n                fill=\"none\"\n                stroke={rank === 1 ? \"#f59e0b\" : \"#64748b\"}\n                strokeDasharray={`${score}, 100`}\n                strokeWidth=\"3.5\"\n                strokeLinecap=\"round\"\n              />\n            </svg>\n          </div>\n        </div>\n      </div>\n\n      {/* Action / Explanation Box complying with Rule 7 */}\n      <div className=\"bg-slate-50 border border-slate-100 rounded-xl p-3 flex flex-start gap-2\">\n        <div className=\"text-slate-600 text-[11px] leading-relaxed flex-1 italic\">\n          \"{reason}\"\n        </div>\n      </div>\n\n      {/* Metrics breakdown grid */}\n      <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3 pt-1 border-t border-slate-100\">\n        <div className=\"flex flex-col gap-0.5\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <MapPin className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Rerata Jarak</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-bold text-xs\">{supporting_metrics.avg_distance_km} km</span>\n        </div>\n\n        <div className=\"flex flex-col gap-0.5\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <TrendingUp className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Aktivitas (Radius)</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-bold text-xs\">{supporting_metrics.activity_count_in_area} kali</span>\n        </div>\n\n        <div className=\"flex flex-col gap-0.5 col-span-2 md:col-span-1\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <DollarSign className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Koefisien Variasi</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-bold text-xs\">CV: {supporting_metrics.consistency_cv}</span>\n        </div>\n\n        <div className=\"flex flex-col gap-0.5\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <DollarSign className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Tertagih Sekitar</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-bold text-xs\">\n            Rp {supporting_metrics.total_transaction_amount_in_area.toLocaleString(\"id-ID\")}\n          </span>\n        </div>\n\n        <div className=\"flex flex-col gap-0.5\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <Users className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Total Beban</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-thin text-xs\">\n            {supporting_metrics.active_customers} nasabah aktif\n          </span>\n        </div>\n\n        <div className=\"flex flex-col gap-0.5\">\n          <div className=\"flex items-center gap-1 text-slate-400\">\n            <Calendar className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[10px]\">Aktivitas Terakhir</span>\n          </div>\n          <span className=\"font-mono text-slate-800 font-bold text-xs\">{supporting_metrics.last_activity_date}</span>\n        </div>\n      </div>\n\n      {/* Confidence Pill Bar */}\n      <div className=\"flex items-center justify-between mt-1 text-[11px] border-t border-slate-50 pt-3\">\n        <span className=\"text-slate-400 flex items-center gap-1 font-mono text-[9px] tracking-wider uppercase font-semibold\">\n          Confidence Rating\n        </span>\n        <span className={`px-2.5 py-0.5 border rounded-full font-bold tracking-tight text-[10px] ${confStyle}`}>\n          {confidence}\n        </span>\n      </div>"
        replacement_content: "  const getRankStyle = (r: number) => {\n    if (r === 1) {\n      return {\n        card: \"bg-white border-slate-200 shadow-sm hover:border-slate-300\",\n        badge: \"bg-slate-800 text-white rounded font-mono\",\n        icon: <Award className=\"w-4 h-4 text-slate-600\" />,\n      };\n    }\n    if (r === 2) {\n      return {\n        card: \"bg-white border-slate-200 shadow-xs hover:border-slate-300\",\n        badge: \"bg-slate-500 text-white rounded font-mono\",\n        icon: <Award className=\"w-4 h-4 text-slate-400\" />,\n      };\n    }\n    return {\n      card: \"bg-white border-slate-200/60 shadow-xs hover:border-slate-300\",\n      badge: \"bg-slate-300 text-slate-700 rounded font-mono\",\n      icon: <User className=\"w-4 h-4 text-slate-400\" />,\n    };\n  };\n\n  const style = getRankStyle(rank);\n  const confStyle = getConfStyle(confidence);\n\n  return (\n    <div\n      onClick={onSelect}\n      className={`rounded-xl border p-4 transition-all duration-150 cursor-pointer flex flex-col gap-3.5 relative overflow-hidden text-left ${style.card} ${\n        isSelected ? \"border-blue-400 ring-2 ring-blue-500/5 bg-slate-50/40\" : \"\"\n      }`}\n      id={`collector-card-${collector_code}`}\n    >\n      {/* Top Banner Row */}\n      <div className=\"flex items-center justify-between\">\n        <div className=\"flex items-center gap-2.5\">\n          <span className={`w-5 h-5 flex items-center justify-center text-[11px] font-bold ${style.badge}`} id={`badge-rank-${collector_code}`}>\n            #{rank}\n          </span>\n          <div>\n            <h4 className=\"font-sans font-bold text-slate-800 tracking-tight text-sm flex items-center gap-1\">\n              Kolektor {collector_code}\n            </h4>\n            <div className=\"flex items-center gap-1 mt-0.5\">\n              <span className=\"text-[9px] text-slate-400 uppercase tracking-wider font-semibold\">\n                Kandidat Terpilih {rank === 1 ? \"Utama\" : `Cadangan #${rank - 1}`}\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* Global score indicator */}\n        <div className=\"flex items-center gap-2\">\n          <div className=\"text-right\">\n            <div className=\"text-xl font-bold text-slate-800 leading-none\">\n              {score}\n              <span className=\"text-[10px] font-normal text-slate-400 ml-0.5\">/100</span>\n            </div>\n            <span className=\"text-[8px] text-slate-400 font-mono tracking-wider\">SKOR MATCH</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Action / Explanation Box complying with Rule 7 */}\n      <div className=\"bg-slate-50 border border-slate-100 rounded-lg p-2.5\">\n        <div className=\"text-slate-605 text-[11px] leading-relaxed text-slate-600 italic\">\n          \"{reason}\"\n        </div>\n      </div>\n\n      {/* Metrics breakdown grid */}\n      <div className=\"grid grid-cols-2 md:grid-cols-3 gap-2.5 pt-2 border-t border-slate-100\">\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold\">Rerata Jarak</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5\">{supporting_metrics.avg_distance_km} km</span>\n        </div>\n\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold\">Aktivitas (Radius)</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5\">{supporting_metrics.activity_count_in_area} kali</span>\n        </div>\n\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold font-mono\">Konsistensi CV</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5\">{supporting_metrics.consistency_cv}</span>\n        </div>\n\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold\">Tertagih Sekitar</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5\">\n            Rp {supporting_metrics.total_transaction_amount_in_area.toLocaleString(\"id-ID\")}\n          </span>\n        </div>\n\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold\">Beban Kerja</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5\">\n            {supporting_metrics.active_customers} Nasabah\n          </span>\n        </div>\n\n        <div className=\"flex flex-col\">\n          <span className=\"text-[9px] uppercase tracking-wider text-slate-400 font-semibold font-mono\">Recency</span>\n          <span className=\"font-mono text-slate-700 font-medium text-xs mt-0.5 text-right md:text-left\">{supporting_metrics.last_activity_date}</span>\n        </div>\n      </div>\n\n      {/* Confidence Pill Bar */}\n      <div className=\"flex items-center justify-between text-[11px] border-t border-slate-100 pt-2 shadow-none\">\n        <span className=\"text-slate-400 flex items-center gap-1 font-mono text-[8px] tracking-wider uppercase font-semibold\">\n          Confidence Level\n        </span>\n        <span className={`px-2 py-0.5 border rounded text-[9px] font-bold ${confStyle}`}>\n          {confidence}\n        </span>\n      </div>"
