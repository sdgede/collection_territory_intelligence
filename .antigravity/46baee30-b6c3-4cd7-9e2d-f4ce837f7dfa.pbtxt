        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Determine if it\'s a cold start scenario (no activities of any collector within 3.0km)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const isColdStart = !statsList.some((s) => s.hasActivitiesInRadius);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // MAX values for scaling subscores"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let maxWeightFreq = Math.max(...statsList.map((s) => s.weightedFrequency));"
