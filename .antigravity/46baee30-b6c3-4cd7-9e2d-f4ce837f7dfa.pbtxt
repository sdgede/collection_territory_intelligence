        }
        lines {
          text: "  const minAvgDistance = Math.min(...statsList.map((s) => s.avgDistance));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const maxAvgDistance = Math.max(...statsList.map((s) => s.avgDistance));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const items: CollectorResult[] = statsList.map((stats) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const code = stats.collector_code;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Subscore 1: Kedekatan wilayah (35%)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let kedekatanScore = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (isColdStart) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // In Cold Start, use absolute inverse of average distance. Let\'s map 0 km to 100 and >= 50 km to 0."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      kedekatanScore = Math.max(0, Math.min(100, Math.round(100 * (1 - stats.avgDistance / 50))));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (maxAvgDistance === minAvgDistance) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        kedekatanScore = stats.avgDistance <= 1.0 ? 100 : stats.avgDistance <= 3.0 ? 70 : 40;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        kedekatanScore = Math.round((100 * (maxAvgDistance - stats.avgDistance)) / (maxAvgDistance - minAvgDistance));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Subscore 2: Frekuensi aktivitas (25%)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let frekuensiScore = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (maxWeightFreq > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      frekuensiScore = Math.round((100 * stats.weightedFrequency) / maxWeightFreq);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Subscore 3: Jumlah transaksi (15%)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let transaksiScore = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (maxWeightTx > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      transaksiScore = Math.round((100 * stats.weightedTransaction) / maxWeightTx);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Subscore 4: Konsistensi kunjungan (15%)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // calculate Coefficient of Variation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let consistencyCV = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let consistencyScore = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (stats.hasActivitiesInRadius) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const sum = stats.weeklyCounts.reduce((a, b) => a + b, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const mean = sum / totalWeeks;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (mean > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const stdDev = calculateStandardDeviation(stats.weeklyCounts, mean);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        consistencyCV = stdDev / mean;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Consistency score is 100 - (CV * 100)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        consistencyScore = Math.max(0, Math.min(100, Math.round(100 - consistencyCV * 100)));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // No visits in radius -> minimum consistency score"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      consistencyCV = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      consistencyScore = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Subscore 5: Beban kerja (10%)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bebanScore = 100;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (maxActiveCustomers > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      bebanScore = Math.round(100 * (1 - stats.profile.active_customers / maxActiveCustomers));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Final Weighted score"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const finalScore = Math.round("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      kedekatanScore * 0.35 +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        frekuensiScore * 0.25 +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        transaksiScore * 0.15 +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        consistencyScore * 0.15 +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        bebanScore * 0.1"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Confidence Level"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let confidence: \"HIGH\" | \"MEDIUM\" | \"LOW\" = \"LOW\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (isColdStart) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      confidence = \"LOW\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else if (stats.recentInRadiusCount >= 10 && consistencyCV < 0.5) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      confidence = \"HIGH\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else if (stats.totalInRadius >= 3) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      confidence = \"MEDIUM\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
