        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const stats = collectorsStats[code];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const dist = haversineDistance(act.latitude, act.longitude, customer.latitude, customer.longitude);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const actDate = new Date(act.activity_date);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const daysAgo = (referenceDate.getTime() - actDate.getTime()) / (1000 * 60 * 60 * 24);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
