        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Calculate final base metrics for each collector"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const statsList = Object.values(collectorsStats);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  statsList.forEach((stats) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (stats.weightSum > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats.avgDistance = stats.weightedDistanceSum / stats.weightSum;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
