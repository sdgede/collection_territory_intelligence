  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport express from \"express\";\nimport path from \"path\";\nimport { createServer as createViteServer } from \"vite\";\nimport { runAnalysis } from \"./src/engine\";\nimport { GoogleGenAI } from \"@google/genai\";\n\nasync function startServer() {\n  const app = express();\n  const PORT = 3000;\n\n  // JSON body parser with increased limit for larger activity streams\n  app.use(express.json({ limit: \"15mb\" }));\n\n  // Headless analyses REST API route\n  app.post(\"/api/analyze\", async (req, res) => {\n    try {\n      const { customer, activities, profiles, reference_date } = req.body;\n\n      if (!customer || !activities || !profiles) {\n        return res.status(400).json({\n          error: \"Format input tidak lengkap. Harap sertakan \'customer\', \'activities\', dan \'profiles\' dalam body request.\",\n        });\n      }\n\n      // 1. Run our bulletproof deterministic engineering scoring model\n      const baseReport = runAnalysis(customer, activities, profiles, reference_date);\n\n      // 2. Enhance summary and actions with Gemini if process.env.GEMINI_API_KEY is available\n      const apiKey = process.env.GEMINI_API_KEY;\n      if (apiKey && apiKey !== \"MY_GEMINI_API_KEY\" && apiKey.trim() !== \"\") {\n        try {\n          const ai = new GoogleGenAI({\n            apiKey: apiKey,\n            httpOptions: {\n              headers: {\n                \"User-Agent\": \"aistudio-build\",\n              },\n            },\n          });\n\n          const prompt = `Lakukan peninjauan hasil komparasi teritori kolektor berikut untuk nasabah ${customer.customer_name}:\n          \n          Data Nasabah:\n          - ID: ${customer.customer_id}\n          - Alamat: ${customer.address}\n          \n          Daftar Rekomendasi Kolektor Teratas:\n          ${JSON.stringify(\n            baseReport.top_collectors.map((col) => ({\n              rank: col.rank,\n              collector_code: col.collector_code,\n              score: col.score,\n              confidence: col.confidence,\n              reason: col.reason,\n              metrics: col.supporting_metrics,\n            })),\n            null,\n            2\n          )}\n\n          Tulis ringkasan eksekutif, analisis risiko, dan tindakan harian konkret rekomendasi dalam Bahasa Indonesia yang taktis.\n          Patuhi format instruksi JSON persis:\n          {\n            \"executive_summary\": \"Tulis penjelasan maksimal 150 kata.\",\n            \"risk_analysis\": [\"risiko 1\", \"risiko 2\"],\n            \"recommended_actions\": [\"tindakan harian 1\", \"tindakan harian 2\"]\n          }`;\n\n          const response = await ai.models.generateContent({\n            model: \"gemini-3.5-flash\",\n            contents: prompt,\n            config: {\n              systemInstruction: \"Anda adalah sistem kecerdasan teritori koleksi (Collection Territory Intelligence System) tingkat lanjut. Tugas Anda adalah menyusun tinjauan analis cerdas dalam Bahasa Indonesia yang sangat informatif, formal, bersandar pada fakta numerik, tanpa bualan/praising berlebihan. Kembalikan HANYA JSON murni sesuai petunjuk.\",\n              responseMimeType: \"application/json\",\n            },\n          });\n\n          if (response.text) {\n            const cleanText = response.text.trim();\n            const gResponse = JSON.parse(cleanText);\n            \n            if (gResponse.executive_summary) {\n              baseReport.executive_summary = gResponse.executive_summary;\n            }\n            if (gResponse.risk_analysis && Array.isArray(gResponse.risk_analysis)) {\n              // Combine generated with any critical base limitations/cold start rules\n              baseReport.risk_analysis = [...new Set([...baseReport.risk_analysis, ...gResponse.risk_analysis])];\n            }\n            if (gResponse.recommended_actions && Array.isArray(gResponse.recommended_actions)) {\n              baseReport.recommended_actions = gResponse.recommended_actions;\n            }\n          }\n        } catch (gemError) {\n          console.warn(\"Gemini API enhancement failed or rate-limited; falling back smoothly to rule-based summary.\", gemError);\n          // Silently continue with deterministic fallback\n        }\n      }\n\n      // Return ONLY raw valid JSON as mandated by Output Rules (GLOBAL)\n      res.setHeader(\"Content-Type\", \"application/json; charset=utf-8\");\n      return res.json(baseReport);\n    } catch (e: any) {\n      console.error(e);\n      return res.status(500).json({ error: \"Gagal memproses analisis teritori: \" + e.message });\n    }\n  });\n\n  // Serve static UI assets to visitors on Port 3000\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \"dist\");\n    app.use(express.static(distPath));\n    app.get(\"*\", (req, res) => {\n      res.sendFile(path.join(distPath, \"index.html\"));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`[Collection Territory Intelligence System] Server running on http://0.0.0.0:${PORT}`);\n  });\n}\n\nstartServer();\n"
    }
