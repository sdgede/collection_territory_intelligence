        }
        lines {
          text: "  const dist = item.supporting_metrics.avg_distance_km;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const count = item.supporting_metrics.activity_count_in_area;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const cv = item.supporting_metrics.consistency_cv;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
